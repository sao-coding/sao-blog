{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "prebuild": "bun run generate-types",
    "dev": "cd ../../ && bun --env-file=apps/server/.env --watch apps/server/src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "@sao-blog/api": "workspace:*",
    "@sao-blog/auth": "workspace:*",
    "@sao-blog/db": "workspace:*",
    "@sao-blog/env": "workspace:*",
    "@sinclair/typebox": "^0.34.48",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.1",
    "elysia": "catalog:",
    "pg": "^8.19.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@sao-blog/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/pg": "^8.16.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "tsdown": "^0.16.5",
    "tsx": "^4.21.0",
    "typescript": "catalog:"
  }
}
